<form>
    <div class="form-group">
        <div class="form-fields">
            <div>
                <label>{{localize "CM.dialog.newBuilding.name.label"}}</label>
                <input class="field-value center" type="text" name="name" 
                placeholder="{{localize "CM.dialog.newBuilding.name.placeholder"}}" 
                    value="{{localize "CM.dialog.newBuilding.name.default.value"}}" />
            </div>
            <div>
                <label>{{localize "CM.dialog.newBuilding.nbr.label"}}</label>
                <input class="field-value center" type="number" name="nbr" value="1" />
            </div>
            <div>
                <label>{{localize "CM.dialog.newBuilding.price.label"}}</label>
                <input class="field-value center" type="number" name="price" value="1" />
            </div>
            <div>
                <label>{{localize "CM.dialog.newBuilding.cost.label"}}</label>
                <input class="field-value center" type="number" name="cost" value="0" />
            </div>
        </div>
    </div>
</form>
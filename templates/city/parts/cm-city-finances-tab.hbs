<section class='tab finances {{tab.cssClass}}' data-group='primary' data-tab='finances'>
  <!-- Treasury -->
  <div class="flexrow no-wrap cm-cities-app-tab-header cm-cities-app-treasury-currencies">
    <div class="flex1 left">{{localize "CM.app.tab.treasury.currencies"}}</div>
    <div class="flex1 left" style="gap:4px;">
      <i title="{{localize "CM.currency.pp.label"}}" class="fas fa-coins" style="color:dimgray"></i>
      <input class="field-value center" name="city.finances.treasury.currencies.pp" type="number"
        value="{{city.finances.treasury.currencies.pp}}" data-dtype="Number" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="flex1 left" style="gap:4px;">
      <i title="{{localize "CM.currency.gp.label"}}" class="fas fa-coins" style="color:goldenrod"></i>
      <input class="field-value center" name="city.finances.treasury.currencies.gp" type="number"
        value="{{city.finances.treasury.currencies.gp}}" data-dtype="Number" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="flex1 left" style="gap:4px;">
      <i title="{{localize "CM.currency.sp.label"}}" class="fas fa-coins" style="color:silver"></i>
      <input class="field-value center" name="city.finances.treasury.currencies.sp" type="number"
        value="{{city.finances.treasury.currencies.sp}}" data-dtype="Number" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="flex1 left" style="gap:4px;">
      <i title="{{localize "CM.currency.cp.label"}}" class="fas fa-coins" style="color:saddlebrown"></i>
      <input class="field-value center" name="city.finances.treasury.currencies.cp" type="number"
        value="{{city.finances.treasury.currencies.cp}}" data-dtype="Number" {{#unless isEditable}}disabled{{/unless}}>
    </div>
  </div>
  <hr>
  <!-- Entries -->
  <div class="cm-cities-app-tab-header flexrow table-header no-wrap" style="gap:4px">
    <div class="center">
      <div class="field-label">{{localize "CM.app.tab.finances.entries.header.label"}}</div>
    </div>
    <div class="flex1 center">
      <div class="field-label">{{localize "CM.app.tab.finances.entries.header.type"}}</div>
    </div>
    <div class="flex1 center">
      <div class="field-label"><span title="Value"><i title="{{localize " CM.currency.sp.label"}}" class="fas fa-coins"
            style="color:#c0c0c0"></i> {{localize "CM.app.tab.finances.entries.header.value"}}</span></div>
    </div>
    <div class="flex1 center" style="max-width: 40px;">
      <div class="field-label"></div>
    </div>
  </div>
  {{#if hasNoEntries}}<p class="center"><i>{{localize "CM.app.tab.finances.entries.empty"}}</i></p>{{/if}}
  {{#each city.finances.entries}}
  <div class="flexrow no-wrap cm-cities-app-tab-line" style="gap:4px">
    <div class="flex0">
        <i class="{{type.icon}}"></i>
    </div>
    <div>
      <!-- label -->
      <input class="field-value center" type="text" name="city.finances.entries.{{@key}}.label" value="{{label}}"
        {{#unless @root.isEditable}}disabled{{/unless}} />
    </div>
    <div class="flex1 center">
      <!-- type -->
      <select class="field-value center" name="city.finances.entries.{{@key}}.type" value="{{type}}" {{#unless
        @root.isEditable}}disabled{{/unless}}>
        {{selectOptions @root.financeEntryTypes selected=type.key valueAttr="key" labelAttr="label" localize=true}}
      </select>
    </div>
    <div class="flex1 center">
      <!-- value -->
      <input class="field-value center" type="text" data-dtype="Number" name="city.finances.entries.{{@key}}.value"
        value="{{value}}" {{#unless @root.isEditable}}disabled{{/unless}} />
    </div>
    <div class="flex1 center" style="max-width: 40px;">
      {{#if @root.isEditable}}
      <button type="button" data-action="removeFinanceEntry" data-id="{{id}}"><i class='fas fa-trash'></i></button>
      {{/if}}
    </div>
  </div>
  {{/each}}
  <!-- New entry button -->
  {{#if isEditable}}
  <div class="cm-cities-app-tab-header right cm-cities-app-tab-line">
    <button type="button" data-action="addNewFinanceEntry"><i class='fas fa-plus'></i> {{localize
      "CM.app.tab.finances.entries.new.btn"}}</button>
  </div>
  {{/if}}
  <hr>
  <!-- total line -->
  <div class="cm-cities-app-tab-header cm-cities-app-tab-line right" style="gap:4px">
    <!-- Treasury -->
    <div class="flex1 right">
      <div class="field-label">{{localize "CM.app.tab.finances.total.treasury.label"}}</div>
    </div>
    <div class="flex1 center">
      <input readonly="true" data-dtype="Number" type="text" class="field-value center"
        value="{{city.finances.total.treasury}}" />
    </div>
    <!-- Incomes -->
    <div class="flex1 right">
      <div class="field-label">{{localize "CM.app.tab.finances.total.incomes.label"}}</div>
    </div>
    <div class="flex1 center">
      <input readonly="true" data-dtype="Number" type="text" class="field-value center"
        value="{{city.finances.total.incomes}}" />
    </div>
    <!-- Expenses -->
    <div class="flex1 right">
      <div class="field-label">{{localize "CM.app.tab.finances.total.expenses.label"}}</div>
    </div>
    <div class="flex1 center">
      <input readonly="true" data-dtype="Number" type="text" class="field-value center"
        value="{{city.finances.total.expenses}}" />
    </div>
    <!-- Armies -->
    <div class="flex1 right">
      <div class="field-label">{{localize "CM.app.tab.finances.total.armies.label"}}</div>
    </div>
    <div class="flex1 center">
      <input readonly="true" data-dtype="Number" type="text" class="field-value center"
        value="{{city.finances.total.armies}}" />
    </div>
  </div>
  <div class="cm-cities-app-tab-header cm-cities-app-tab-line right" style="gap:4px">
    <!-- Total -->
    <div class="flex1 right">
      <div class="field-label">{{localize "CM.app.tab.finances.total.label"}}</div>
    </div>
    <div class="flex1 center">
      <input readonly="true" data-dtype="Number" type="text" class="field-value center"
        value="{{city.finances.total.value}}" />
    </div>
  </div>
</section>